<Application x:Class="ProformaCombiner.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uiMarkup="clr-namespace:Wpf.Ui.Markup;assembly=Wpf.Ui"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <uiMarkup:ThemesDictionary Theme="Dark" />
                <uiMarkup:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Tile styling -->
            <Style TargetType="ToggleButton" x:Key="TileToggleStyle">
                <Setter Property="Margin" Value="8" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Width" Value="360" />
                <Setter Property="MinHeight" Value="110" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="#1E1E1E" />
                <Setter Property="BorderBrush" Value="#3A3A3A" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border CornerRadius="12"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Border x:Name="Accent" Width="6" CornerRadius="12,0,0,12" HorizontalAlignment="Left" Background="#C8102E" />
                                    <ContentPresenter Margin="14,10,10,10" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#6A6A6A" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#2A2323" />
                                    <Setter TargetName="Accent" Property="Background" Value="#FFCC00" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
