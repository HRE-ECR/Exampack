<ui:FluentWindow x:Class="ProformaCombiner.Wpf.Views.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                mc:Ignorable="d"
                Title="Proforma Combiner" Height="760" Width="1100"
                WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Width="110" Height="40" Margin="0,0,10,0" Click="AT300_Click">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Document" Margin="0,0,8,0" />
                    <TextBlock Text="AT300" FontWeight="SemiBold" />
                </StackPanel>
            </ui:Button>

            <ui:Button Grid.Column="1" Width="110" Height="40" Margin="0,0,10,0" Click="AT200_Click" Appearance="Secondary">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Document" Margin="0,0,8,0" />
                    <TextBlock Text="AT200" FontWeight="SemiBold" />
                </StackPanel>
            </ui:Button>

            <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="10" Background="#1C1C1C" Padding="12,8" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <ui:Button Grid.Column="3" Width="160" Height="40" Click="Export_Click" Appearance="Primary">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Save" Margin="0,0,8,0" />
                    <TextBlock Text="Export Selection" FontWeight="SemiBold" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <Border Grid.Row="1" Margin="0,16,0,12" CornerRadius="14" Background="#141414" BorderBrush="#2B2B2B" BorderThickness="1" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton Style="{StaticResource TileToggleStyle}" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Record.Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Margin="0,10,0,0" Foreground="#CFCFCF"
                                               Text="{Binding Record.PagesText, StringFormat=Pages: {0}}" />
                                </Grid>
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Tip: Click tiles to select. Page supports ranges (2-6) and copies (4x3)." Foreground="#AFAFAF" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
