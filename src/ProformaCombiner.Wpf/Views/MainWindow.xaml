<Window x:Class="ProformaCombiner.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Proforma Combiner" Height="760" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Width="110" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="AT300_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="AT300" />
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Width="110" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="AT200_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="AT200" />
                </StackPanel>
            </Button>

            <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ️" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Button Grid.Column="3" Width="180" Style="{StaticResource PrimaryButton}" Click="Export_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="Export Selection" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Tiles -->
        <Border Grid.Row="1" Margin="0,16,0,12" CornerRadius="14" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton Style="{StaticResource TileToggleStyle}" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Record.Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding Record.PagesText, StringFormat=Pages: {0}}" />
                                </Grid>
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Tip: Click tiles to select. Page supports ranges (2-6) and copies (4x3)." Foreground="#AFAFAF" />
        </StackPanel>
    </Grid>
</Window>
